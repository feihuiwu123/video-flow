# Videoflow Environment Variables Template
# Copy this file to .env and fill in your credentials.
# DO NOT commit .env to version control!

# =============================================================================
# 🔑 API Keys (按模块分类)
# =============================================================================

# ---------------------------------------------------------------
# 🤖 M2 - LLM 解析器 (DeepSeek 优先, OpenAI/Anthropic 备选)
# ---------------------------------------------------------------
# DeepSeek (推荐 - 性价比高,中文支持好)
# 申请地址: https://platform.deepseek.com/api_keys
# 模型: deepseek-chat (默认), deepseek-coder
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (备选)
# 申请地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (备选)
# 申请地址: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# 🗣️ M2 - TTS 语音合成 (至少申请一个)
# ---------------------------------------------------------------
# Azure Speech (推荐,支持中文高质量语音)
# 申请地址: https://azure.microsoft.com/services/cognitive-services/speech-services/
# AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_SPEECH_REGION=eastus

# ElevenLabs (高质量语音克隆)
# 申请地址: https://elevenlabs.io/api
# ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# 🎬 M3.4b - Pexels 库存视频 API
# 申请地址: https://www.pexels.com/api/
# 免费额度: 200请求/月, 10000图片/月
# ---------------------------------------------------------------
# PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# 🔄 LiteLLM 代理 (可选,用于统一接口)
# 申请地址: https://docs.litellm.ai/
# ---------------------------------------------------------------
# LITELLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# LITELLM_BASE_URL=https://api.litellm.ai  # 或自托管地址


# =============================================================================
# ⚙️ 可选配置 (一般不需要修改)
# =============================================================================

# ---------------------------------------------------------------
# M2 - LLM 模型配置
# ---------------------------------------------------------------
# DeepSeek 模型
# DEEPSEEK_MODEL=deepseek-chat
# DeepSeek API 地址 (使用代理时需要)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 模型
# OPENAI_MODEL=gpt-4o

# Anthropic 模型
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------
# M3.2 - faster-whisper 模型配置 (本地,无需申请)
# ---------------------------------------------------------------
# 模型大小: tiny, base, small, medium, large-v2, large-v3
# ALIGN_MODEL_SIZE=base
# HuggingFace 缓存目录
# HF_HOME=/path/to/cache

# ---------------------------------------------------------------
# M3.3 - Playwright 配置 (无需申请,安装浏览器即可)
# ---------------------------------------------------------------
# PLAYWRIGHT_BROWSER_PATH=
# PLAYWRIGHT_VIEWPORT_WIDTH=1920
# PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# ---------------------------------------------------------------
# M3.4b - Pexels 缓存配置
# ---------------------------------------------------------------
# PEXELS_CACHE_DIR=./workspace/stock_cache

# ---------------------------------------------------------------
# 开发调试配置
# ---------------------------------------------------------------
# LOG_LEVEL=INFO
# MCP_DEBUG=false
# VIDEOFLOW_DB_PATH=./workspace/videoflow.db


# =============================================================================
# 📝 申请优先级建议
# =============================================================================
# 1. [高优] DEEPSEEK_API_KEY - M2 LLM 解析必需 (DeepSeek 性价比最高)
# 2. [中优] AZURE_SPEECH_KEY - M2 TTS 升级可选 (edge-tts 已可用)
# 3. [中优] PEXELS_API_KEY - M3.4b 库存视频可选
# 4. [低优] OPENAI_API_KEY / ANTHROPIC_API_KEY - M2 备选 LLM
# 5. [低优] ELEVENLABS_API_KEY - 语音克隆可选
